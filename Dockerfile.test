FROM debian:stable-slim

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends openssl curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Download the binary directly (no install.sh — inside Docker we're already root)
RUN ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') && \
    curl -sSLf "https://github.com/diegovrocha/certui/releases/latest/download/certui_linux_${ARCH}.tar.gz" \
    | tar -xz -C /usr/local/bin certui && \
    chmod +x /usr/local/bin/certui

WORKDIR /certs

CMD ["certui"]
